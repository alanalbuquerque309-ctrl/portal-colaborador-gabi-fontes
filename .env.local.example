# Copie para .env.local — mesmos valores do Vercel (Settings → Environment Variables)
# URL canónica do site (Open Graph / previews). Em produção na Vercel podes omitir (usa VERCEL_URL).
# NEXT_PUBLIC_SITE_URL=https://portal-colaborador-gabi-fontes.vercel.app

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role (apenas servidor) — necessário para finalizar onboarding
SUPABASE_SERVICE_ROLE_KEY=

# Bootstrap do banco (criar tabelas) — use no Vercel para api/admin/bootstrap-db
DATABASE_URL=          # Supabase: Settings → Database → Connection string (URI)
BOOTSTRAP_SECRET=      # Qualquer string secreta para proteger a rota

# Vídeo de boas-vindas no onboarding (YouTube, Vimeo ou URL direta)
NEXT_PUBLIC_VIDEO_BOAS_VINDAS=

# Acesso admin (somente em variáveis de ambiente — não commitar senhas)
# ADMIN_PASSWORD=senha_antiga_unica (opcional)
# ADMIN_ALAN_LOGIN=alan
# ADMIN_ALAN_PASSWORD=obrigatório para a rota /api/login/alan-entrar (bootstrap técnico; login normal = CPF + senha em colaboradores)

# Botão de ajuda rápida (Bloco 10)
NEXT_PUBLIC_WHATSAPP_AJUDA=5521999999999   # Número com DDI, sem + ou espaços
NEXT_PUBLIC_EMAIL_AJUDA=rh@gabifontes.com.br
